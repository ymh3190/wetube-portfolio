extends layouts/main

block content
    .upload-video
        form.upload-video__form(action=routes.uploadVideo, method="post", enctype="multipart/form-data")
            input(type="file", name="videoFile", placeholder="Select file", accept="video/*")
            input(type="text", name="title", placeholder="Title")
            textarea(name="description", placeholder="description")
            input(type="submit", value="Upload video")